#. Plugin Name of the plugin
#: estimate.php
msgid "Estimate - Request a Quote for WooCommerce"
msgstr "Estimate - Zapytanie ofertowe dla WooCommerce"

#. Plugin URI of the plugin
#: estimate.php
msgid "https://plogins.com/estimate/"
msgstr "https://plogins.com/estimate/"

#. Description of the plugin
#: estimate.php
msgid "Let customers request a quote instead of buying directly — ideal for B2B and made-to-order."
msgstr "Pozwól klientom wysłać zapytanie ofertowe zamiast kupować bezpośrednio — idealne dla B2B i produktów na zamówienie."

#. Author of the plugin
#: estimate.php
msgid "WPPoland"
msgstr "WPPoland"

#. Author URI of the plugin
#: estimate.php
msgid "https://plogins.com/"
msgstr "https://plogins.com/"

#: estimate.php:47
msgid "Estimate - Request a Quote for WooCommerce requires WooCommerce to be active."
msgstr "Estimate - Zapytanie ofertowe dla WooCommerce wymaga aktywnego WooCommerce."

#: src/Admin/ProductData.php:39
#: src/Admin/Settings.php:114
msgid "Enable quote requests"
msgstr "Włącz zapytania ofertowe"

#: src/Admin/ProductData.php:41
msgid "Quote mode is set to \"all products\", so every product already shows an Add to quote button."
msgstr "Tryb zapytań ofertowych jest ustawiony na „wszystkie produkty”, więc każdy produkt wyświetla już przycisk Dodaj do zapytania."

#: src/Admin/ProductData.php:42
msgid "Hide the price and add-to-cart button and show an \"Add to quote\" button instead."
msgstr "Ukryj cenę i przycisk dodawania do koszyka, a zamiast nich pokaż przycisk „Dodaj do zapytania”."

#: src/Admin/Settings.php:52
msgid "Estimate — Request a Quote"
msgstr "Estimate — Zapytanie ofertowe"

#: src/Admin/Settings.php:53
msgid "Estimate"
msgstr "Estimate"

#: src/Admin/Settings.php:90
msgid "Let customers request a quote"
msgstr "Pozwól klientom wysyłać zapytania ofertowe"

#: src/Admin/Settings.php:92
msgid "Turn products into quote requests instead of direct purchases — ideal for B2B, bulk or made-to-order items. Customers build a quote list and send you their details; each request is emailed to you and saved for review."
msgstr "Zamień produkty na zapytania ofertowe zamiast bezpośrednich zakupów — idealne dla produktów B2B, hurtowych lub na zamówienie. Klienci tworzą listę zapytania i przesyłają swoje dane; każde zapytanie jest wysyłane do Ciebie e-mailem i zapisywane do przeglądu."

#. translators: %s: shortcode wrapped in <code>.
#: src/Admin/Settings.php:98
#, php-format
msgid "Add the %s shortcode to a page to show the quote list and request form."
msgstr "Dodaj shortcode %s do strony, aby wyświetlić listę zapytania i formularz."

#: src/Admin/Settings.php:109
msgid "General"
msgstr "Ogólne"

#: src/Admin/Settings.php:121
msgid "Show quote requests on the storefront."
msgstr "Wyświetlaj zapytania ofertowe w sklepie."

#: src/Admin/Settings.php:127
msgid "Quote mode"
msgstr "Tryb zapytań ofertowych"

#: src/Admin/Settings.php:132
msgid "Selected products only"
msgstr "Tylko wybrane produkty"

#: src/Admin/Settings.php:135
msgid "All products"
msgstr "Wszystkie produkty"

#: src/Admin/Settings.php:139
msgid "In \"selected\" mode, enable individual products via the \"Enable quote requests\" checkbox in the product data box."
msgstr "W trybie „wybrane” włącz poszczególne produkty za pomocą pola wyboru „Włącz zapytania ofertowe” w sekcji danych produktu."

#: src/Admin/Settings.php:145
msgid "Hide price"
msgstr "Ukryj cenę"

#: src/Admin/Settings.php:152
msgid "Hide the price on quote-enabled products."
msgstr "Ukryj cenę na produktach z włączonym zapytaniem ofertowym."

#: src/Admin/Settings.php:158
msgid "Button text"
msgstr "Tekst przycisku"

#: src/Admin/Settings.php:164
#: src/Service/QuoteProducts.php:191
