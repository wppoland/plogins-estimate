#: src/Admin/Settings.php:177
msgid "Recipient email"
msgstr "Adres e-mail odbiorcy"

#: src/Admin/Settings.php:185
msgid "Where new quote requests are emailed. Leave blank to use the site admin email."
msgstr "Adres, na który wysyłane są nowe zapytania ofertowe. Pozostaw puste, aby użyć adresu e-mail administratora witryny."

